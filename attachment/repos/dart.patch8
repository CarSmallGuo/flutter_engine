 #include "platform/signal_blocker.h"
@@ -279,6 +280,7 @@ bool OSThread::GetCurrentStackBounds(uword* lower, uword* upper) {
 
 #if defined(USING_SAFE_STACK)
 NO_SANITIZE_ADDRESS
+NO_SANITIZE_HWADDRESS
 NO_SANITIZE_SAFE_STACK
 uword OSThread::GetCurrentSafestackPointer() {
 #error "SAFE_STACK is unsupported on this platform"
@@ -286,6 +288,7 @@ uword OSThread::GetCurrentSafestackPointer() {
 }
 
 NO_SANITIZE_ADDRESS
+NO_SANITIZE_HWADDRESS
 NO_SANITIZE_SAFE_STACK
 void OSThread::SetCurrentSafestackPointer(uword ssp) {
 #error "SAFE_STACK is unsupported on this platform"


