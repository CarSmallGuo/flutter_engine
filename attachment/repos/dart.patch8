   # buildtools/third_party/libc++abi) instead of stdlibc++ as standard library.
   # This is intended to be used for instrumented builds.
   use_custom_libcxx =
-      (is_asan && (is_linux || is_ohos)) || is_lsan || is_msan || is_tsan || is_ubsan
+      ((is_asan || is_hwasan) && (is_linux || is_ohos)) || is_lsan || is_msan || is_tsan || is_ubsan
 
   # Track where uninitialized memory originates from. From fastest to slowest:
   # 0 - no tracking, 1 - track only the initial allocation site, 2 - track the
diff --git a/runtime/platform/hwaddress_sanitizer.h b/runtime/platform/hwaddress_sanitizer.h
new file mode 100644
index 00000000000..367620e7e9b
--- /dev/null
+++ b/runtime/platform/hwaddress_sanitizer.h
@@ -0,0 +1,32 @@
+/*
+* Copyright 2021-2024 Huawei Device Co., Ltd. All rights reserved.
+* Use of this source code is governed by a BSD-style license that
+* can be found in the LICENSE file.
+*/
+
+#ifndef RUNTIME_PLATFORM_HWADDRESS_SANITIZER_H_
+#define RUNTIME_PLATFORM_HWADDRESS_SANITIZER_H_
+
+#include <sanitizer/hwasan_interface.h>
+#include "platform/globals.h"
+
+#if __SANITIZE_HWADDRESS__
+#define USING_HWADDRESS_SANITIZER
+#elif defined(__has_feature)
+#if __has_feature(hwaddress_sanitizer)
+#define USING_HWADDRESS_SANITIZER
+#endif
+#endif
+
+#if defined(USING_HWADDRESS_SANITIZER)
+#define NO_SANITIZE_HWADDRESS __attribute__((no_sanitize("hwaddress")))
+//The memory size of hwasan must be aligned with 16 bytes
+#define HWASAN_UNPOISON(ptr, len) __hwasan_tag_memory(ptr, 0, ((len) + 15) & ~15)
+#else  // defined(USING_HWADDRESS_SANITIZER)
+#define NO_SANITIZE_HWADDRESS
+#define HWASAN_UNPOISON(ptr, len)                                                \
+  do {                                                                         \
+  } while (false && (ptr) == nullptr && (len) == 0)
+#endif  // defined(USING_HWADDRESS_SANITIZER)
+
+#endif  // RUNTIME_PLATFORM_HWADDRESS_SANITIZER_H_
diff --git a/runtime/vm/exceptions.cc b/runtime/vm/exceptions.cc
index d24b2d5eeb9..a970ea40832 100644
--- a/runtime/vm/exceptions.cc
+++ b/runtime/vm/exceptions.cc
@@ -7,6 +7,7 @@
 #include "vm/exceptions.h"
 
 #include "platform/address_sanitizer.h"
+#include "platform/hwaddress_sanitizer.h"
 #include "platform/thread_sanitizer.h"
 
 #include "lib/stacktrace.h"
@@ -658,6 +659,8 @@ void Exceptions::JumpToFrame(Thread* thread,
   uword current_sp = OSThread::GetCurrentStackPointer() - 1024;
   ASAN_UNPOISON(reinterpret_cast<void*>(current_sp),
                 stack_pointer - current_sp);
+  HWASAN_UNPOISON(reinterpret_cast<void*>(current_sp),
+                  stack_pointer - current_sp);
 
   // We are jumping over C++ frames, so we have to set the safestack pointer
   // back to what it was when we entered the runtime from Dart code.
diff --git a/runtime/vm/os_thread_ohos.cc b/runtime/vm/os_thread_ohos.cc
index d5fbff8f79e..2bb1be4a032 100644
--- a/runtime/vm/os_thread_ohos.cc
+++ b/runtime/vm/os_thread_ohos.cc
@@ -16,6 +16,7 @@
