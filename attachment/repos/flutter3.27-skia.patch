++    int values[2]; // value[0] - to save 'weight', value[1] - to save 'to'
++    for (unsigned int i = 0; i < sizeof(tags) / sizeof(char*); i++) {
++        const char* key = tags[i];
++        if (!root.isMember(key)) {
