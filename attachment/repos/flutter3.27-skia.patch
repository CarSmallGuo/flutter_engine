++            (void) logErrInfo(ERROR_CONFIG_INVALID_VALUE_TYPE, text.c_str(), Json::objectValue,
++                fallbackArr[i].type());
++            continue;
++        }
++        parseFallbackItem(fallbackArr[i]);
++    }
++    FallbackSetPos setPos = {startPos, (unsigned int)(fallbackSet.size() - startPos)};
