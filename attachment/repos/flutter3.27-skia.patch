++void FontConfig_OHOS::buildSubTypefaceSet(const std::shared_ptr<TypefaceSet>& typefaceSet,
++    std::shared_ptr<TypefaceSet>& subSet, const SkString& familyName, int weight)
++{
++    if (typefaceSet->size() == 0) {
++        return;
